@page "/Notifications"
@inject NavigationManager Nav

<PageTitle>Notifications | Vertex University</PageTitle>

<div class="animate-fade-in pb-5">
    <div class="glass-morphism rounded-5 p-5 mb-5 shadow-lg bg-indigo text-white">
        <h1 class="display-4 fw-bold">Notifications</h1>
        <p class="lead opacity-75">Stay updated with the latest event changes and campus news.</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-lg-8">
            <div class="glass-morphism rounded-5 border-0 bg-white shadow-sm p-4">
                <div class="d-flex align-items-center gap-3 p-3 bg-indigo-soft rounded-4 mb-3">
                    <div class="bg-indigo p-2 rounded-circle shadow-sm">
                        <i class="bi bi-info-circle text-white"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="fw-bold text-indigo-900 mb-0">System Update</h6>
                        <p class="text-muted small mb-0">Event categories and filtering are now live!</p>
                    </div>
                    <span class="badge rounded-pill bg-light text-muted border py-2 px-3 fw-bold">NEW</span>
                </div>

                <div class="d-flex align-items-center gap-3 p-3 rounded-4 mb-3 border">
                    <div class="bg-light p-2 rounded-circle shadow-inner">
                        <i class="bi bi-check2-circle text-success"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="fw-bold text-muted mb-0">Registration Confirmed</h6>
                        <p class="text-muted small mb-0">You've successfully registered for the Annual Tech Symposium.</p>
                    </div>
                    <span class="text-muted extra-small">2h ago</span>
                </div>

                <div class="d-flex align-items-center gap-3 p-3 rounded-4 mb-3 border">
                    <div class="bg-light p-2 rounded-circle shadow-inner">
                        <i class="bi bi-heart-fill text-danger"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="fw-bold text-muted mb-0">Wishlist Reminder</h6>
                        <p class="text-muted small mb-0">'Spring Music Festival' is happening in 2 days!</p>
                    </div>
                    <span class="text-muted extra-small">5h ago</span>
                </div>

                <div class="text-center mt-4 pt-3">
                    <button class="btn btn-outline-secondary rounded-pill px-4 fw-bold" @onclick='() => Nav.NavigateTo("/Events")'>
                        Go to Events
                    </button>
                    <button class="btn btn-link text-indigo fw-bold ms-3">Mark all as read</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-indigo { background: var(--vertex-indigo); }
    .bg-indigo-soft { background: rgba(79, 70, 229, 0.1); }
    .text-indigo { color: var(--vertex-indigo); }
    .text-indigo-900 { color: #312e81; }
    .extra-small { font-size: 0.7rem; }
</style>
