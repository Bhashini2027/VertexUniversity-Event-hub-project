@page "/MyRegistrations"
@using VertexUniversity.Models
@inject AppState AppState
@inject IJSRuntime JS
@inject NavigationManager Nav

@code {
    private List<Event> registeredEventsList = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        await LoadRegisteredEvents();
    }

    private async Task LoadRegisteredEvents()
    {
        isLoading = true;
        try
        {
            var allEvents = await JS.InvokeAsync<List<Event>>("firebaseInterop.getEvents");
            registeredEventsList = allEvents.Where(e => AppState.RegisteredEvents.Contains(e.Id)).ToList();
        }
        finally
        {
            isLoading = false;
        }
    }

    public void Dispose() => AppState.OnChange -= StateHasChanged;
}

<div class="animate-fade-in pb-5">
    <div class="glass-morphism rounded-5 p-5 mb-5 shadow-lg bg-indigo text-white">
        <h1 class="display-4 fw-bold">My Registrations</h1>
        <p class="lead opacity-75">Your personal dashboard for upcoming campus experiences.</p>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-indigo" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!registeredEventsList.Any())
    {
        <div class="glass-morphism text-center py-5 rounded-5 border-0 bg-white shadow-sm">
            <i class="bi bi-journal-x text-muted display-1 mb-4 d-block opacity-25"></i>
            <h3 class="fw-bold text-dark">No registrations yet</h3>
            <p class="text-muted">Start exploring events and join the campus community!</p>
            <button class="btn btn-indigo rounded-pill mt-3 px-5 py-2 shadow-sm" @onclick='() => Nav.NavigateTo("/Events")'>Browse Events</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var eventItem in registeredEventsList)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card card-registration h-100 border-0 rounded-5 shadow-sm overflow-hidden bg-white">
                        <img src="@eventItem.Image" class="card-img-top object-fit-cover" style="height: 160px;" alt="@eventItem.Title">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge bg-indigo-soft text-indigo rounded-pill small">@eventItem.Category</span>
                                <span class="ms-auto text-success small fw-bold"><i class="bi bi-patch-check-fill me-1"></i> Registered</span>
                            </div>
                            <h5 class="fw-bold text-indigo-900 mb-3 text-truncate">@eventItem.Title</h5>
                            <div class="small text-muted mb-3">
                                <p class="mb-1"><i class="bi bi-calendar3 me-2 text-indigo"></i> @eventItem.Date</p>
                                <p class="mb-0"><i class="bi bi-geo-alt me-2 text-indigo"></i> @eventItem.Location</p>
                            </div>
                            <button class="btn btn-outline-indigo w-100 rounded-pill py-2 fw-bold" @onclick='() => Nav.NavigateTo($"/EventDetails/{eventItem.Id}")'>
                                View Details
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .card-registration { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .card-registration:hover { transform: translateY(-5px); }
    .bg-indigo { background: linear-gradient(135deg, #4f46e5 0%, #312e81 100%); }
    .bg-indigo-soft { background: rgba(79, 70, 229, 0.1); }
    .text-indigo { color: #4f46e5; }
    .text-indigo-900 { color: #312e81; }
    .btn-indigo { background: #4f46e5; color: white; border: none; }
    .btn-outline-indigo { border: 2px solid #4f46e5; color: #4f46e5; background: transparent; }
    .btn-outline-indigo:hover { background: #4f46e5; color: white; }
</style>
