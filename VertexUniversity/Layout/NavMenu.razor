@using VertexUniversity.Models
@inject AppState AppState
@inject NavigationManager Nav

<div class="sidebar-container h-100 d-flex flex-column p-3 glass-morphism rounded-right-5 shadow-lg border-0">
    <div class="logo-section mb-5 px-3 pt-4">
        <div class="d-flex align-items-center gap-2">
            <div class="bg-indigo p-2 rounded-3 shadow-sm">
                <i class="bi bi-mortarboard-fill text-white fs-4"></i>
            </div>
            <div>
                <h5 class="fw-bold mb-0 text-indigo-900">UNIVERSITY</h5>
                <small class="text-indigo fw-bold tracking-widest text-uppercase" style="font-size: 0.6rem;">VERTEX</small>
            </div>
        </div>
    </div>

    <nav class="flex-grow-1">
        <div class="nav-group mb-4">
            <small class="text-muted fw-bold text-uppercase px-3 mb-2 d-block tracking-wider" style="font-size: 0.65rem;">Main Menu</small>
            
            <NavLink class="nav-link-premium" href="" Match="NavLinkMatch.All">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </NavLink>

            <NavLink class="nav-link-premium" href="Events">
                <i class="bi bi-calendar2-event-fill"></i>
                <span>All Events</span>
            </NavLink>

            <NavLink class="nav-link-premium" href="Calendar">
                <i class="bi bi-calendar3"></i>
                <span>Calendar View</span>
            </NavLink>
        </div>

        <div class="nav-group mb-4">
            <small class="text-muted fw-bold text-uppercase px-3 mb-2 d-block tracking-wider" style="font-size: 0.65rem;">@(AppState.IsAdmin ? "Administration" : "Student Hub")</small>
            
            @if (!AppState.IsAdmin)
            
              {  <NavLink class="nav-link-premium" href="MyRegistrations">
                    <i class="bi bi-journal-check"></i>
                    <span>My Registrations</span>
                </NavLink>
                
                <NavLink class="nav-link-premium" href="ManageEvents">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span>Submit Event</span>
                </NavLink>
            
                
            
                <NavLink class="nav-link-premium" href="ManageEvents">
                    <i class="bi bi-gear-wide-connected"></i>
                    <span>Event Management</span>
                </NavLink>

                <NavLink class="nav-link-premium disabled-link" href="#">
                    <i class="bi bi-people"></i>
                    <span>Student Records</span>
                </NavLink>
            }
        </div>
    </nav>

    <div class="user-section mt-auto p-3 glass-morphism rounded-4 shadow-sm border border-indigo-light">
        <div class="d-flex align-items-center gap-3 mb-3 px-2">
            <div class="bg-indigo-soft rounded-circle p-1 overflow-hidden shadow-inner" style="width: 44px; height: 44px;">
                <img src="https://ui-avatars.com/api/?name=@(AppState.UserName)&background=4f46e5&color=fff" class="w-100 h-100 rounded-circle" />
            </div>
            <div class="text-truncate">
                <p class="mb-0 fw-bold small text-indigo-900">@AppState.UserName</p>
                <p class="mb-0 text-muted d-flex align-items-center gap-1" style="font-size: 0.65rem;">
                    <i class="bi @(AppState.IsAdmin ? "bi-shield-lock-fill text-danger" : "bi-person-fill text-success")"></i>
                    @(AppState.IsAdmin ? "Administrator" : "Verified Student")
                </p>
            </div>
        </div>
        @if (AppState.IsAdmin)
        {
            <button class="btn btn-danger btn-sm w-100 rounded-pill py-2 fw-bold text-white shadow-sm border-0 transition-all hover-glow" @onclick="Logout">
                <i class="bi bi-box-arrow-right me-2"></i> Logout Admin
            </button>
        }
        else
        {
            <button class="btn btn-indigo-gradient btn-sm w-100 rounded-pill py-2 fw-bold text-white shadow-sm border-0 transition-all hover-glow" @onclick='() => Nav.NavigateTo("/ManageEvents")'>
                <i class="bi bi-shield-lock me-2"></i> Admin Panel
            </button>
        }
    </div>
</div>

<style>
    .bg-indigo-soft { background: rgba(79, 70, 229, 0.1); }
    .border-indigo-light { border: 1px solid rgba(79, 70, 229, 0.2) !important; }
    .btn-indigo-gradient { 
        background: linear-gradient(135deg, #4f46e5 0%, #7e22ce 100%); 
        transition: all 0.3s ease;
    }
    .btn-indigo-gradient:hover { 
        transform: translateY(-2px); 
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3) !important;
        background: linear-gradient(135deg, #4338ca 0%, #6b21a8 100%);
    }
    .hover-glow:active { transform: scale(0.98); }

    .sidebar-container { 
        width: 280px; 
        min-height: 100vh;
        z-index: 100;
        background: rgba(255, 255, 255, 0.6) !important;
        backdrop-filter: blur(20px) !important;
    }
    .rounded-right-5 { border-top-right-radius: 2.5rem; border-bottom-right-radius: 2.5rem; }
    .text-indigo-900 { color: #312e81; }
    .tracking-wider { letter-spacing: 0.1em; }
    .tracking-widest { letter-spacing: 0.2em; }
    .bg-indigo { background-color: var(--vertex-indigo); }
    .text-indigo { color: var(--vertex-indigo); }
    .btn-indigo { background-color: var(--vertex-indigo); color: white; }
    .btn-indigo:hover { background-color: #4338ca; color: white; }

    .nav-link-premium {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0.85rem 1.25rem;
        margin: 0.25rem 0.5rem;
        border-radius: 1rem;
        color: #64748b;
        font-weight: 500;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
    }

    .nav-link-premium i { font-size: 1.25rem; }
    .nav-link-premium:hover { background: rgba(79, 70, 229, 0.05); color: var(--vertex-indigo); }
    .nav-link-premium.active { background: var(--vertex-indigo); color: white; box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.3); }

    .disabled-link { opacity: 0.5; pointer-events: none; }
</style>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    private async Task Logout()
    {
        await AppState.Logout();
        Nav.NavigateTo("/Events");
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}

